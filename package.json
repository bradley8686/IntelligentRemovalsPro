{
  "name": "intelligent-removals-pro",
  "version": "1.0.0",
  "productName": "Intelligent Removals Pro",
  "description": "AI-powered video inventory and lorry recommendation app for house removals.",
  "author": "Intelligent Removals Pro",
  "license": "Proprietary",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --check main.js && node --check create-icon-pack.js && node --check survey-calculator.js && node --check service-worker.js",
    "training:sort": "node scripts/sort-training-captures.js",
    "build:win": "electron-builder --win nsis",
    "build:mac": "electron-builder --mac dmg",
    "build:linux": "electron-builder --linux AppImage deb",
    "build": "electron-builder -mwl"
  },
  "build": {
    "appId": "com.intelligentremovals.app",
    "productName": "Intelligent Removals Pro",
    "asar": true,
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!dist/**/*",
      "!.git/**/*",
      "!.github/**/*",
      "!build/__tmp__/**/*",
      "!*.bat",
      "!*.zip",
      "!penny_bot.txt"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Intelligent Removals Pro"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "bradley8686",
        "repo": "IntelligentRemovalsPro"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bradley8686/IntelligentRemovalsPro"
  },
  "devDependencies": {
    "@fiahfy/icns": "^0.0.7",
    "archiver": "^7.0.1",
    "electron": "^39.1.1",
    "electron-builder": "^25.0.0",
    "icon-gen": "^5.0.0",
    "png-to-ico": "^3.0.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  }
}
